{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf --connect-timeout 0.1 -X POST http://127.0.0.1:${GAME_HUB_PORT:-41731}/event -H 'Content-Type: application/json' -d '{\"event\":\"prompt_submit\"}' || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf --connect-timeout 0.1 -X POST http://127.0.0.1:${GAME_HUB_PORT:-41731}/event -H 'Content-Type: application/json' -d '{\"event\":\"stop\"}' || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf --connect-timeout 0.1 -X POST http://127.0.0.1:${GAME_HUB_PORT:-41731}/event -H 'Content-Type: application/json' -d '{\"event\":\"notification\"}' || true"
          }
        ]
      }
    ]
  }
}
